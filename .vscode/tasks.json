{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "npm: install",
			"type": "shell",
			"command": "npm",
			"args": ["install"],
			"group": "build"
		},
		{
			"label": "npm: dev",
			"type": "shell",
			"command": "npm",
			"args": ["run", "dev"],
			"isBackground": true,
			"group": {
				"kind": "build",
				"isDefault": true
			},
			"problemMatcher": {
				"pattern": {
					"regexp": "^.*$",
					"file": 1,
					"location": 2,
					"message": 3
				},
				"background": {
					"activeOnStart": true,
					"beginsPattern": "VITE.*listening",
					"endsPattern": "ready in"
				}
			}
		},
		{
			"label": "npm: build",
			"type": "shell",
			"command": "npm",
			"args": ["run", "build"],
			"group": "build",
			"problemMatcher": ["$tsc"]
		}
	]
}